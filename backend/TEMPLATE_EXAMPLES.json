      "name": "order_tracking",
      "category": "UTILITY",
      "language": "en_US",
      "components": [
        {
          "type": "HEADER",
          "format": "TEXT",
          "text": "Order #{{1}}"
        },
        {
          "type": "BODY",
          "text": "Hi {{2}}, your order has been confirmed! Total: ${{3}}. Expected delivery: {{4}}"
