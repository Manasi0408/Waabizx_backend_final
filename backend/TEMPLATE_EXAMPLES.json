        {
          "type": "HEADER",
          "format": "TEXT",
          "text": "Special Offer"
        },
        {
          "type": "BODY",
          "text": "Hi {{1}}! Get {{2}}% off on {{3}}. Use code: {{4}}"
        },
        {
          "type": "FOOTER",
          "text": "Valid until {{5}}"
        },
        {
          "type": "BUTTONS",
          "buttons": [
            {
              "type": "URL",
