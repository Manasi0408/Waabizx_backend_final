  "usage": {
    "description": "Copy any example and use it with POST /api/templates/create",
    "example_curl": "curl -X POST http://localhost:5000/api/templates/create -H \"Content-Type: application/json\" -H \"Authorization: Bearer YOUR_TOKEN\" -d @template.json"
  }
}

